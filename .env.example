# =============================================================================
# Limen — example environment configuration.
#
# Copy to `.env` and adjust. Nested config uses `__` (env_nested_delimiter).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16 + PostGIS)
# -----------------------------------------------------------------------------
# Local Docker (default for `make up-dev`):
DB__CONNECTION_STRING=postgresql://limen:limen@localhost:5432/limen

# Pool sizing
DB__POOL_MIN_SIZE=2
DB__POOL_MAX_SIZE=20

# --- Neon (serverless Postgres) example ---
# Neon does NOT support pg_cron — keep SCHEDULER__CACHE_CLEANUP=apscheduler.
# Use sslmode=require. No code changes needed; only this var changes.
#DB__CONNECTION_STRING=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/limen?sslmode=require

# -----------------------------------------------------------------------------
# Object store
#   backend = filesystem | s3
#   filesystem is the default for dev/demo.
#   s3 targets any S3-compatible endpoint (MinIO sidecar on the VPS,
#   Cloudflare R2, Backblaze B2). Use
#   OBJECT_STORE__ENDPOINT_URL to point at the non-AWS endpoint.
# -----------------------------------------------------------------------------
OBJECT_STORE__BACKEND=filesystem
OBJECT_STORE__ROOT=./object_store_root

# --- MinIO sidecar example (set OBJECT_STORE__BACKEND=s3) ---
#OBJECT_STORE__BUCKET=limen
#OBJECT_STORE__PREFIX=raster/
#OBJECT_STORE__ENDPOINT_URL=http://minio:9000
#OBJECT_STORE__ACCESS_KEY_ID=minioadmin
#OBJECT_STORE__SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# LLM provider precedence:
#   1) ANTHROPIC_API_KEY  → Anthropic
#   2) OPENAI_API_KEY     → OpenAI
#   3) FOUNDRY_*          → Microsoft Foundry
#   4) (fallback)         → Ollama (LLM__OLLAMA_BASE_URL)
# A cloud key always wins over Ollama unless LLM__PROVIDER overrides explicitly.
# -----------------------------------------------------------------------------
#LLM__PROVIDER=                       # anthropic | openai | foundry | ollama
#LLM__MODELS__ORCHESTRATOR=claude-opus-4-7
#LLM__MODELS__SCORER=claude-sonnet-4-6
#LLM__MODELS__SUMMARIZER=claude-haiku-4-5

# Three interchangeable backends (mirrors mcp-geo-server) — pick ONE:
#
# 1) Host Ollama (default in produzione): no key. On the host use localhost;
#    inside `make up` containers it is host.docker.internal automatically.
#    LLM__OLLAMA_MODEL is the single model served for every agent role
#    (default qwen3.6:latest).
LLM__OLLAMA_BASE_URL=http://localhost:11434
#LLM__OLLAMA_MODEL=qwen3.6:latest
#
# 2) Ollama Cloud (https://ollama.com): base_url + bearer key, force provider.
#LLM__PROVIDER=ollama
#LLM__OLLAMA_BASE_URL=https://ollama.com
#LLM__OLLAMA_API_KEY=
#
# 3) Claude API: set the key (auto-detected; wins over Ollama).
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#FOUNDRY_ENDPOINT=
#FOUNDRY_API_KEY=

# -----------------------------------------------------------------------------
# Scheduler
#   cache_cleanup = pg_cron | apscheduler
#   Use `apscheduler` on Neon (pg_cron unavailable).
# -----------------------------------------------------------------------------
SCHEDULER__CACHE_CLEANUP=apscheduler
SCHEDULER__CACHE_CLEANUP_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false

# -----------------------------------------------------------------------------
# Notifications (Phase 7) — Strategy pattern: list channels in
# NOTIFICATIONS__ENABLED_CHANNELS. Channels whose creds are missing
# degrade to a no-op (logged), they DON'T error. Multiple at once OK.
# Format must be a JSON array, e.g. '["telegram","mqtt"]'.
# -----------------------------------------------------------------------------
#NOTIFICATIONS__ENABLED_CHANNELS=["telegram","mqtt","email"]

# --- Telegram ---
#NOTIFICATIONS__TELEGRAM__BOT_TOKEN=
#NOTIFICATIONS__TELEGRAM__CHAT_ID=
#NOTIFICATIONS__TELEGRAM__PARSE_MODE=HTML

# --- MQTT (V1 demo uses Mosquitto in docker-compose.demo.yml) ---
#NOTIFICATIONS__MQTT__BROKER_HOST=localhost
#NOTIFICATIONS__MQTT__BROKER_PORT=1883
#NOTIFICATIONS__MQTT__TOPIC=limen/alerts
#NOTIFICATIONS__MQTT__USERNAME=
#NOTIFICATIONS__MQTT__PASSWORD=
#NOTIFICATIONS__MQTT__TLS=false
#NOTIFICATIONS__MQTT__QOS=1

# --- Email (SMTP) ---
#NOTIFICATIONS__EMAIL__SMTP_HOST=smtp.example.com
#NOTIFICATIONS__EMAIL__SMTP_PORT=587
#NOTIFICATIONS__EMAIL__USERNAME=
#NOTIFICATIONS__EMAIL__PASSWORD=
#NOTIFICATIONS__EMAIL__FROM_ADDRESS=alerts@limen.example
#NOTIFICATIONS__EMAIL__RECIPIENTS=["ops@example.com"]
#NOTIFICATIONS__EMAIL__USE_STARTTLS=true

# --- Dispatch rules ---
ALERT__MIN_LEVEL=Moderate         # Low | Moderate | High | VeryHigh
ALERT__MIN_STATIC_S=0.5           # below-High cells alert only if S >= this (susceptible slope)
ALERT__DEDUP_WINDOW_MINUTES=180   # suppress a repeat alert for the same cell
ALERT__TOP_K=5                    # cells highlighted in the payload
ALERT__MAP_BASE_URL=http://localhost:5173

# =============================================================================
# GeoServer vector-data layer (opt-in — mcp-geo-server integration)
#
# Activated only by the `geoserver` compose profile:
#   docker compose -f infra/docker/docker-compose.geoserver.yml \
#     --profile geoserver up -d      (or `make geoserver-up`)
#
# A dedicated Postgres+PostGIS holds the vector layers; GeoServer serves
# them as OGC WMS/WFS. The application images are pulled pre-built from
# GHCR. Endpoints (host ports remapped to coexist with the Limen stack):
#   GeoServer  -> http://localhost:8081/geoserver  (admin/geoserver)
#   Web UI     -> http://localhost:8000
#   MCP agent  -> http://localhost:9000/mcp
#   PostGIS    -> localhost:55433 (gis/gis/gis)
# =============================================================================
# GHCR image refs (override to pin a tag or use a locally-built image).
#GEOSERVER_APP_IMAGE=ghcr.io/agent-engineering-studio/mcp-geo-server:latest
#GEOSERVER_BOOTSTRAP_IMAGE=ghcr.io/agent-engineering-studio/mcp-geo-server:bootstrap

# GeoServer admin credentials (change for anything beyond local testing).
#GEOSERVER_ADMIN_USER=admin
#GEOSERVER_ADMIN_PASSWORD=geoserver

# Shapefile source loaded by the one-shot bootstrap. Defaults to the sibling
# mcp-geoserver repo's ./data. Point at a subset (e.g. Puglia+Basilicata) for
# a faster first test.
#GEOSERVER_SHAPEFILE_DIR=../../../mcp-geoserver/data
#GEO_INIT_WORKSPACE=ispra
#GEO_INIT_DATASTORE=ispra_pg
#GEO_INIT_FORCE=false          # true = drop & reload existing tables (destructive)
#GEO_INIT_SHAPE_ENCODING=ISO-8859-1

# LLM for the natural-language MCP agent: ollama (host, default) | anthropic.
#GEO_LLM_PROVIDER=ollama
#GEO_OLLAMA_HOST=http://host.docker.internal:11434
#OLLAMA_LLM_MODEL=qwen2.5
# Destructive GeoServer tools (delete/WFS-T) are blocked unless true.
#GEO_ALLOW_DESTRUCTIVE=false

# --- GeoServer as the authoritative source of ISPRA static data ---
# When set, `limen geoserver-sync` (and `limen bootstrap-static`) load the
# IFFI landslide inventory + PAI hazard mosaic from the GeoServer PostGIS
# into the operational iffi_landslides / pai_hazard tables, replacing the
# IdroGeo WFS ingest. Unset ⇒ loader is a no-op. Host port is 55433.
#GEOSERVER_SOURCE__DB_DSN=postgresql://gis:gis@localhost:55433/gis
#GEOSERVER_SOURCE__SCHEMA_NAME=public

# --- DTM (terrain) → slope/aspect/curvature for the S component ---
# The DTM GeoTIFF lives in the /data folder shared with the GeoServer
# container. A single internally-tiled GeoTIFF (e.g. the national 5 m
# HR-DTM, EPSG:6875, 256×256 blocks) works directly — windowed reads touch
# only the blocks under each cell, so the file size is irrelevant. For MANY
# separate tiles, build a virtual mosaic first (`make dtm-vrt`) instead.
#LIMEN_DEM_RASTER=../mcp-geoserver/data/HRDTM5m.tif

# --- CORINE Land Cover 2018 (landuse_code per cell) ---
# Open download (no login): SINAnet ISPRA publishes the CLC2018 Italy
# shapefile; rasterize CODE_18 at 100 m for the majority-class zonal:
#   gdal_rasterize -sql "SELECT CAST(CODE_18 AS INTEGER) AS code, geometry
#     FROM CLC18_IT" -dialect sqlite -a code -tr 100 100 -a_nodata 0 \
#     -ot Int16 -co COMPRESS=DEFLATE -co TILED=YES CLC18_IT.shp clc2018.tif
# Source: https://groupware.sinanet.isprambiente.it/uso-copertura-e-consumo-di-suolo/library/copertura-del-suolo/corine-land-cover
#LIMEN_CORINE_RASTER=../mcp-geoserver/data/clc2018_it/clc2018_it_100m.tif

# --- Carta Geolitologica d'Italia 1:500k (litho_weight per cell) ---
# Open WFS (CC-BY, Geoportale Nazionale PCN/MASE), layer GE.CARTAGEOLITOLOGICA:
#   ogr2ogr -f "ESRI Shapefile" carta_geolitologica.shp \
#     "WFS:http://wms.pcn.minambiente.it/ogc?map=/ms_ogc/wfs/Carta_geolitologica.map" \
#     GE.CARTAGEOLITOLOGICA -t_srs EPSG:4326 -nlt PROMOTE_TO_MULTI
# The lithology labels live in `legenda_li` (matched by LITHO_WEIGHTS substrings).
#LIMEN_GEOLOGICAL_SHAPEFILE=../mcp-geoserver/data/carta_geolitologica/carta_geolitologica.shp
#LIMEN_GEOLOGICAL_FIELD=legenda_li

# --- ITALICA / e-ITALICA dated landslide catalogue (backtest truth set) ---
# The §2.5 backtest replays against dated landslide events (all Italy,
# 1996–2021); IFFI on its own is an undated inventory. `limen ingest-events`
# auto-downloads e-ITALICA v4 from the pinned Zenodo DOI (10.5281/zenodo.
# 14204473, CC-BY-4.0) into LIMEN_DATA_DIR and caches it — no manual step.
# Override only to pin a different version or run fully offline:
#LIMEN_DATA_DIR=./data                 # where downloaded datasets are cached
#LIMEN_ITALICA_CSV=./data/ITALICA_v4.csv   # explicit local file (skips download)
#LIMEN_ITALICA_URL=https://zenodo.org/api/records/14204473/files/ITALICA_v4.csv/content
# Backtest antecedent-rainfall product: CERRA (5.5 km regional reanalysis,
# 1985–2021) resolves localized triggering rain far better than ERA5 (~28 km).
# Node grid step in degrees defaults to 0.1° (~11 km) to exploit CERRA.
#LIMEN_BACKTEST_RAIN_MODEL=cerra        # or era5_seamless / blank for ERA5
#LIMEN_BACKTEST_RAIN_NODE_DEG=0.1
# Warning horizon: an alert up to this many hours before the event is a hit
# (antecedent-driven landslides warn days ahead; default 120 h / 5 days).
#LIMEN_BACKTEST_LEAD_MAX_HOURS=120

# --- Live monitoring rainfall grid ---
# The hourly MeteoFetch samples precipitation on a node grid over the AOI
# bbox (forecast API, batched ~100 nodes/call) and each cell gets its
# nearest node's series — one regional centroid misses localized convective
# rain. Grid step in degrees; 0 disables (centroid-only).
#METEO_RAIN_NODE_DEG=0.25

# =============================================================================
# Knowledge-graph grounding (V2.x) — advisory, off by default
# =============================================================================
# When enabled, the BriefingAgent calls the KG sidecar's POST /query for
# (region, mechanism) supporting passages and appends Markdown citations
# to the Italian narrative. KG failures degrade silently; numeric scoring
# outputs are NEVER affected.
KG__ENABLED=false
KG__BASE_URL=http://localhost:8000
KG__THREAD_ID=landslide-kb
KG__TIMEOUT_SECONDS=3.0          # hard ceiling — briefing never stalls beyond this
KG__CACHE_TTL_SECONDS=3600       # (region, mechanism) cache lifetime in app_cache
KG__TOP_K=4
#KG__API_TOKEN=                  # optional bearer for the sidecar

# =============================================================================
# Clerk auth (protected FastAPI endpoints) — off by default
# =============================================================================
# When enabled, operator endpoints (POST /api/monitor/{aoi}) require a valid
# Clerk session JWT, verified against the instance JWKS (public keys; the
# secret key is never used server-side). Public read-only map endpoints stay
# open. The Vite frontend uses VITE_CLERK_PUBLISHABLE_KEY (frontend/.env.local).
CLERK__ENABLED=false
#CLERK__JWKS_URL=https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
#CLERK__ISSUER=https://<your-frontend-api>.clerk.accounts.dev
#CLERK__AUTHORIZED_PARTIES=["http://localhost:5173"]
