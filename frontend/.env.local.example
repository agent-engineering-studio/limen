# Limen frontend — example local environment.
#
# Copy to `.env.local` for local development. Vite reads variables
# prefixed with VITE_ at build time; nothing else is exposed to the
# browser.

# Backend FastAPI URL (Phase 5).
VITE_API_URL=http://localhost:8080

# pg_tileserv URL the browser fetches vector tiles from. In the
# docker-compose.demo.yml stack this is :7800. The FastAPI /api/tiles
# proxy redirects to the same host, so either value works.
VITE_TILESERV_URL=http://localhost:7800

# Optional feature flags
VITE_ENABLE_TIMELINE=true
VITE_ENABLE_GRAPH=false

# Default map centre + zoom — Puglia/Basilicata pilot.
VITE_DEFAULT_LON=16.6
VITE_DEFAULT_LAT=40.5
VITE_DEFAULT_ZOOM=7
