{# src/limen/report/templates/report.html.j2 #}
<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ view.title }}</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  :root { color-scheme: light; }
  body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
         color: #1a1a1a; background: #f5f6f8; }
  header { background: #1a2733; color: #fff; padding: 1.5rem 2rem; }
  header h1 { margin: 0 0 .25rem; font-size: 1.4rem; }
  header .meta { opacity: .8; font-size: .85rem; }
  main { max-width: 960px; margin: 0 auto; padding: 1.5rem 2rem 3rem; }
  .national { background: #fff; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem;
              box-shadow: 0 1px 4px rgba(0,0,0,.08); }
  .national p { white-space: pre-line; }
  .cluster { background: #fff; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem;
             box-shadow: 0 1px 6px rgba(0,0,0,.1); }
  .zonemap { height: 320px; width: 100%; background: #eef1f4; }
  .cluster .body { padding: 1rem 1.25rem; }
  .trend { margin-top: .75rem; }
  .trend-cap { font-size: .75rem; color: #5e6473; margin: 0 0 .25rem; }
  .zone-trend { width: 100%; max-width: 280px; height: 48px; display: block; }
  .badge { display: inline-block; padding: .15rem .6rem; border-radius: 999px; color: #fff;
           font-size: .8rem; font-weight: 600; }
  .coords { font-weight: 600; color: #21456e; margin: .5rem 0 .25rem; font-size: .95rem;
            font-variant-numeric: tabular-nums; }
  .verdict { margin: .5rem 0; font-weight: 600; }
  .verdict-warn { color: #bd0026; } .verdict-watch { color: #b8860b; } .verdict-ok { color: #2e7d32; }
  .bars { margin-top: .75rem; }
  .bar { display: flex; align-items: center; gap: .5rem; margin: .2rem 0; font-size: .8rem; }
  .bar .track { flex: 1; height: 8px; background: #eceef1; border-radius: 4px; overflow: hidden; }
  .bar .fill { height: 100%; }
  .legend { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1rem; font-size: .8rem; }
  .legend span { display: inline-flex; align-items: center; gap: .3rem; }
  .legend .sw { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }
  .notice { background: #eef4fb; border-left: 4px solid #4a72a8; border-radius: 6px;
            padding: .7rem 1rem; margin-bottom: 1.25rem; font-size: .9rem; color: #21456e; }
</style>
</head>
<body>
<header>
  <h1>{{ view.title }}</h1>
  <div class="meta">Valutazione: {{ view.valuation_time }} · pipeline {{ view.pipeline_version }}</div>
</header>
<main>
  {% if view.notice %}<p class="notice">{{ view.notice }}</p>{% endif %}
  <section class="national"><p>{{ view.national_summary }}</p></section>

  {% for c in view.clusters %}
  <article class="cluster">
    <div id="{{ c.map_id }}" class="zonemap" data-geo="geo-{{ c.map_id }}"
         data-lat="{{ c.center_lat }}" data-lon="{{ c.center_lon }}"></div>
    <script type="application/json" id="geo-{{ c.map_id }}">{{ c.geojson|safe }}</script>
    <div class="body">
      <span class="badge" style="background: {{ c.level_color }}">{{ c.level_label }}</span>
      <span> · {{ c.aoi_id }} · {{ c.n_cells }} celle · score {{ '%.2f'|format(c.max_score) }}</span>
      <p class="coords">📍 {{ c.coord_label }}</p>
      <p class="verdict verdict-{{ c.verdict_tone }}">{{ c.verdict_text }}</p>
      <p>{{ c.reason }}</p>
      <div class="bars">
        {% for label, value, color in c.components %}
        <div class="bar"><span>{{ label }}</span>
          <span class="track"><span class="fill" style="width: {{ (value*100)|round(0, 'floor') }}%; background: {{ color }}"></span></span>
        </div>
        {% endfor %}
      </div>
      {% if c.trend_svg %}
      <div class="trend">
        <p class="trend-cap">Andamento rischio · 72 h passate (linea piena) + previsione 72 h (tratteggiata)</p>
        {{ c.trend_svg|safe }}
      </div>
      {% endif %}
    </div>
  </article>
  {% endfor %}

  {% if view.top_comuni %}
  <section class="national">
    <h2>Comuni a maggior rischio</h2>
    <table class="int-table">
      <thead><tr><th>Comune</th><th>Classe</th><th>Celle in allerta</th></tr></thead>
      <tbody>
        {% for c in view.top_comuni %}
        <tr><td>{{ c.name }}</td><td>{{ c.worst_class }}</td><td>{{ c.n_alert }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <div class="legend">
    {% for rc in classes %}
    <span><span class="sw" style="background: {{ rc.color }}"></span>{{ rc.label_it }} ({{ '%.2f'|format(rc.range[0]) }}–{{ '%.2f'|format(rc.range[1]) }})</span>
    {% endfor %}
  </div>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  if (typeof L === "undefined") return;  // Leaflet CDN unreachable — cards still show text/coords
  var TILE = {{ view.basemap_url | tojson }};
  var ATTR = {{ view.basemap_attribution | tojson }};
  function initMap(el) {
    if (el.dataset.ready) return;
    el.dataset.ready = "1";
    var gj = JSON.parse(document.getElementById(el.dataset.geo).textContent);
    var map = L.map(el, { scrollWheelZoom: false });
    L.tileLayer(TILE, { attribution: ATTR, maxZoom: 19 }).addTo(map);
    var layer = L.geoJSON(gj, {
      style: function (f) {
        return { color: "#333", weight: 0.6, fillColor: f.properties.color, fillOpacity: 0.6 };
      },
      onEachFeature: function (f, l) {
        l.bindPopup("Cella " + f.properties.cell_id + " — " + f.properties.level +
                    " (score " + f.properties.score + ")");
      }
    }).addTo(map);
    try { map.fitBounds(layer.getBounds(), { padding: [20, 20], maxZoom: 13 }); }
    catch (e) { map.setView([+el.dataset.lat, +el.dataset.lon], 11); }
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { initMap(e.target); io.unobserve(e.target); }
    });
  }, { rootMargin: "200px" });
  document.querySelectorAll(".zonemap").forEach(function (el) { io.observe(el); });
})();
</script>
</body>
</html>
